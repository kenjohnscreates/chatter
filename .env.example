GEMINI_API_KEY=
UNISWAP_API_KEY=

# Dynamic (client): public environment id exposed to the browser.
NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=

# Dynamic Flow paywall (server-only — NEVER expose the dyn_ token to the browser).
DYNAMIC_API_KEY=dyn_...
DYNAMIC_ENVIRONMENT_ID=
# Optional override; defaults to https://app.dynamicauth.com/api/v0
DYNAMIC_API_BASE=

# Base Sepolia address where the $1 USDC paywall settles.
CHATTER_TREASURY_ADDRESS=0xYourBaseSepoliaTreasuryAddress
