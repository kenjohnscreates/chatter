NEXT_PUBLIC_DYNAMIC_ENVIRONMENT_ID=
NEXT_PUBLIC_API_BASE_URL=http://127.0.0.1:8765

# Swap quotes/execution proxy through the API (UNISWAP_API_KEY on server only).

# false = pre-indexed demo cache (default). true = live last30days scrape.
NEXT_PUBLIC_RESEARCH_LIVE=false
# Cached demo: simulated scan bar duration in ms (0 = instant). Default 10000 (10s).
NEXT_PUBLIC_SIMULATE_RESEARCH_MS=10000
